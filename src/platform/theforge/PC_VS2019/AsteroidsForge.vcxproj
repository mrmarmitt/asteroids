<?xml version="1.0" encoding="utf-8"?>
<!--
  AsteroidsForge — bootstrap do casco (.ai/task/01-bootstrap-casco.md).

  Receita herdada dos irmaos (8PuzzleForge/SpaceInvadersForge): pasta
  PC_VS2019 obrigatoria (o TF_Shared.props seleciona os props de plataforma
  pelo caminho), LibraryPath no build do The-Forge, eventos de build
  sobrescritos (output fora da arvore do The-Forge), rootsigs por-app via
  FSL, /std:c++latest + /Zc:char8_t-, RTTI e excecoes ligados (a cengine
  lanca std::invalid_argument/logic_error; o FlowRouter usa dynamic_cast).

  Novidade deste jogo: as pontes The-Forge vem do checkout irmao
  ../platform-theforge-common (>= 0.1.0) em vez de copiadas — include path +
  .cpp compilados aqui + FSL apontando para a Shaders.list de la.

  Pre-requisitos: solution Unit_Tests do The-Forge buildada na mesma
  Configuration e checkouts irmaos ../cengine (>= 0.6.0, factories
  owned()/hosted() + FlowRouter) e ../platform-theforge-common (>= 0.1.0).
-->
<Project DefaultTargets="Build" ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <ItemGroup>
    <!-- entry point + composition root (na raiz de src, padrao dos irmaos);
         modo PROPRIO: main() + EngineManager::owned() da cengine 0.6.0 -->
    <ClCompile Include="$(GameRoot)src\main_theforge.cpp" />
    <!-- pontes The-Forge do platform-theforge-common (checkout irmao) -->
    <ClCompile Include="$(CommonRoot)src\TheForgeCommon\TheForgeWindowManager.cpp" />
    <ClCompile Include="$(CommonRoot)src\TheForgeCommon\ForgeUi.cpp" />
    <ClCompile Include="$(CommonRoot)src\TheForgeCommon\ForgeSpriteUi.cpp" />
    <!-- plataforma do jogo: factory + cenas -->
    <ClCompile Include="..\src\AsteroidsForge\ForgeSceneFactory.cpp" />
    <ClCompile Include="..\src\AsteroidsForge\scene\ForgeSplashScene.cpp" />
    <ClCompile Include="..\src\AsteroidsForge\scene\ForgeMenuScene.cpp" />
    <ClCompile Include="..\src\AsteroidsForge\scene\ForgeGameScene.cpp" />
    <ClCompile Include="..\src\AsteroidsForge\scene\ForgeGameOverScene.cpp" />
    <!-- dominio do jogo (C++ puro; o mesmo World que a suite CMake exercita —
         GameRouter/estados seguem header-only) -->
    <ClCompile Include="$(GameRoot)src\asteroids\game\World.cpp" />
    <!-- cengine (core + routing) -->
    <ClCompile Include="$(CengineRoot)core\src\EngineManager.cpp" />
    <ClCompile Include="$(CengineRoot)modules\routing\src\GameManager.cpp" />
    <ClCompile Include="$(CengineRoot)modules\routing\src\RouterInMemory.cpp" />
    <ClCompile Include="$(CengineRoot)modules\routing\src\SceneRepository.cpp" />
    <ClCompile Include="$(CengineRoot)modules\collision2d\src\Intersects.cpp" />
  </ItemGroup>
  <ItemGroup>
    <None Include="..\src\AsteroidsForge\GPUCfg\gpu.cfg" />
  </ItemGroup>
  <ItemGroup>
    <!-- shaders do batcher vem do common (rootsigs padrao inclusos); o jogo
         cria a propria Shaders.list quando tiver shaders proprios -->
    <FSLShader Include="$(CommonRoot)src\TheForgeCommon\Shaders\FSL\Shaders.list" />
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{6D037745-B98A-42DF-88F0-C287C61115C7}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <WindowsTargetPlatformVersion>10.0.17763.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v142</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v142</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings">
  </ImportGroup>
  <ImportGroup Label="Shared" />
  <ImportGroup Label="PropertySheets">
    <Import Project="..\..\..\..\..\The-Forge\Examples_3\Build_Props\VS\TF_Shared.props" />
  </ImportGroup>
  <PropertyGroup Label="UserMacros" />
  <PropertyGroup>
    <TFBuildRoot>$(TheForgeRoot)Examples_3\Unit_Tests\PC_VS2019\</TFBuildRoot>
    <GameRoot>$([System.IO.Path]::GetFullPath("$(MSBuildThisFileDirectory)..\..\..\..\"))</GameRoot>
    <CengineRoot>$([System.IO.Path]::GetFullPath("$(GameRoot)..\cengine\"))</CengineRoot>
    <CommonRoot>$([System.IO.Path]::GetFullPath("$(GameRoot)..\platform-theforge-common\"))</CommonRoot>
    <LinkIncremental Condition="'$(Configuration)'=='Debug'">true</LinkIncremental>
    <LinkIncremental Condition="'$(Configuration)'=='Release'">false</LinkIncremental>
    <IntDir>$(GameRoot)out\theforge\$(Platform)\$(Configuration)\Intermediate\$(ProjectName)\</IntDir>
    <OutDir>$(GameRoot)out\theforge\$(Platform)\$(Configuration)\$(ProjectName)\</OutDir>
    <LibraryPath>$(TFBuildRoot)$(Platform)\$(Configuration);$(LibraryPath)</LibraryPath>
    <LocalDebuggerWorkingDirectory>$(OutDir)</LocalDebuggerWorkingDirectory>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeader>
      </PrecompiledHeader>
      <AdditionalIncludeDirectories>$(TheForgeRoot);$(GameRoot)src;$(CengineRoot)core\include;$(CengineRoot)modules\routing\include;$(CengineRoot)modules\collision2d\include;$(CommonRoot)src\TheForgeCommon;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <!-- O The-Forge compila com /GR- e sem /EH, mas o jogo precisa dos dois:
           excecoes na cengine (factories validam colaboradores) e RTTI no
           FlowRouter (dynamic_cast do estado de fluxo). -->
      <RuntimeTypeInfo>true</RuntimeTypeInfo>
      <ExceptionHandling>Sync</ExceptionHandling>
      <LanguageStandard>stdcpplatest</LanguageStandard>
      <!-- u8"" -> const char* nos headers do The-Forge; o char8_t do C++20
           proibe — /Zc:char8_t- restaura o comportamento antigo
           (aprendizado da PoC do 8puzzle). -->
      <AdditionalOptions>/Zc:char8_t- %(AdditionalOptions)</AdditionalOptions>
      <SuppressStartupBanner>true</SuppressStartupBanner>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <EntryPointSymbol>mainCRTStartup</EntryPointSymbol>
      <AdditionalDependencies>
        Xinput9_1_0.lib;
        ws2_32.lib;
        Renderer.lib;
        OS.lib;
        %(AdditionalDependencies);
      </AdditionalDependencies>
      <AdditionalOptions>/ignore:4099</AdditionalOptions>
    </Link>
    <Manifest>
      <AdditionalManifestFiles>$(TFBuildRoot)dpi-aware.manifest %(AdditionalManifestFiles)</AdditionalManifestFiles>
    </Manifest>
    <!-- Sobrescreve os eventos do Examples.x64.props (que assumem output na
         arvore do The-Forge): shaders de fonte/UI do projeto OS antes do link,
         DLLs de runtime e configs depois. -->
    <PreLinkEvent>
      <Command>
        if exist "$(TFBuildRoot)$(Platform)\$(Configuration)\OS\Shaders\" xcopy /Y /S /D "$(TFBuildRoot)$(Platform)\$(Configuration)\OS\Shaders\*" "$(OutDir)Shaders\"
        if exist "$(TFBuildRoot)$(Platform)\$(Configuration)\OS\CompiledShaders\" xcopy /Y /S /D "$(TFBuildRoot)$(Platform)\$(Configuration)\OS\CompiledShaders\*" "$(OutDir)CompiledShaders\"
      </Command>
    </PreLinkEvent>
    <PostBuildEvent>
      <Command>
        xcopy "$(TheForgeRoot)Common_3\Graphics\ThirdParty\OpenSource\VulkanSDK\bin\Win32\*.dll" "$(OutDir)" /S /Y /D
        xcopy "$(TheForgeRoot)Common_3\Graphics\ThirdParty\OpenSource\VulkanSDK\bin\Win32\*.json" "$(OutDir)" /S /Y /D
        xcopy "$(TheForgeRoot)Common_3\Graphics\ThirdParty\OpenSource\ags\ags_lib\lib\amd_ags_x64.dll" "$(OutDir)amd_ags_x64.dll"* /S /Y /D
        xcopy "$(TheForgeRoot)Common_3\Graphics\ThirdParty\OpenSource\DirectXShaderCompiler\bin\x64\dxcompiler.dll" "$(OutDir)dxcompiler.dll"* /S /Y /D
        xcopy "$(TheForgeRoot)Common_3\Graphics\ThirdParty\OpenSource\Direct3d12Agility\bin\x64\*.dll" "$(OutDir)"* /S /Y /D
        xcopy "$(TheForgeRoot)Common_3\Graphics\ThirdParty\OpenSource\winpixeventruntime\bin\WinPixEventRuntime.dll" "$(OutDir)WinPixEventRunTime.dll"* /S /Y /D
        rem PathStatement PROPRIO: os mounts do The-Forge assumem o exe dentro
        rem da arvore dele; o nosso aponta para ../The-Forge a partir do
        rem out/theforge deste repo (repos irmaos no workspace).
        xcopy /Y /D "..\src\$(ProjectName)\PathStatement.txt" "$(OutDir)"
        xcopy /Y /D "..\src\$(ProjectName)\GPUCfg\gpu.cfg" "$(OutDir)"
        xcopy "$(TheForgeRoot)Common_3\OS\Windows\pc_gpu.data" "$(OutDir)gpu.data*" /Y /D

        if not exist "$(OutDir)PipelineCaches\" mkdir "$(OutDir)PipelineCaches\"
        if not exist "$(OutDir)Screenshots\" mkdir "$(OutDir)Screenshots\"
        if not exist "$(OutDir)Debug\" mkdir "$(OutDir)Debug\"
        if not exist "$(OutDir)Scripts\" mkdir "$(OutDir)Scripts\"
      </Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup>
    <FSLShader>
      <OutDir>$(OutDir)Shaders</OutDir>
      <BinaryOutDir>$(OutDir)CompiledShaders</BinaryOutDir>
      <Compile>true</Compile>
      <Language>DIRECT3D12</Language>
    </FSLShader>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
    </ClCompile>
    <Link>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
    </Link>
  </ItemDefinitionGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
    <Import Project="$(TheForgeRoot)Common_3\Tools\ForgeShadingLanguage\VS\fsl.targets" />
  </ImportGroup>
</Project>
